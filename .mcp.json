{
  "mcpServers": {
    "notion": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "NOTION_API_KEY": "${NOTION_API_KEY}"
      }
    },
    "sqlite-multi": {
      "type": "stdio",
      "command": "python",
      "args": ["infrastructure/sqlite-multi-mcp/server.py"]
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y", "@modelcontextprotocol/server-filesystem",
        ".tmp",
        "execution",
        "infrastructure/n8n/logs"
      ]
    },
    "brave-search": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "youtube-data": {
      "type": "stdio",
      "command": "python",
      "args": ["infrastructure/youtube-mcp/server.py"],
      "env": {
        "YOUTUBE_TOKEN_PATH": "token.json"
      }
    },
    "telegram": {
      "type": "stdio",
      "command": "python",
      "args": ["infrastructure/telegram-mcp/server.py"]
    },
    "n8n-workflow": {
      "type": "stdio",
      "command": "python",
      "args": ["infrastructure/n8n-mcp/server.py"]
    },
    "system-monitor": {
      "type": "stdio",
      "command": "python",
      "args": ["infrastructure/system-monitor/server.py"]
    },
    "cloudinary": {
      "type": "stdio",
      "command": "python",
      "args": ["infrastructure/cloudinary-mcp/server.py"]
    }
  }
}
