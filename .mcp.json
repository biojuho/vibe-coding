{
  "mcpServers": {
    "notion": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_API_KEY": "${NOTION_API_KEY}"
      }
    },
    "sqlite-multi": {
      "type": "stdio",
      "command": "python",
      "args": [
        "infrastructure/sqlite-multi-mcp/server.py"
      ]
    },
    "brave-search": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "telegram": {
      "type": "stdio",
      "command": "python",
      "args": [
        "infrastructure/telegram-mcp/server.py"
      ]
    },
    "system-monitor": {
      "type": "stdio",
      "command": "python",
      "args": [
        "infrastructure/system-monitor/server.py"
      ]
    },
    "cloudinary": {
      "type": "stdio",
      "command": "python",
      "args": [
        "infrastructure/cloudinary-mcp/server.py"
      ]
    },
    "code-review-graph": {
      "command": "python3.13",
      "args": [
        "-m",
        "code_review_graph",
        "serve"
      ],
      "env": {
        "PYTHONUTF8": "1"
      },
      "type": "stdio"
    }
  }
}
