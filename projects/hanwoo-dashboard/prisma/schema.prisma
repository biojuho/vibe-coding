generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  // Prisma 7: 'fast' skips full type-check during generation → ~40% faster builds
  compilerBuild = "fast"
}

datasource db {
  provider = "postgresql"
}

enum OutboxStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FarmSettings {
  id        String   @id @default("default")
  name      String   @default("Joolife Farm")
  location  String   @default("Namwon")
  latitude  Float    @default(35.446)
  longitude Float    @default(127.344)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Building {
  id          String          @id @default(cuid())
  name        String
  penCount    Int             @default(32)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  cattle      Cattle[]
  feedRecords FeedRecord[]
  expenses    ExpenseRecord[]
}

model Cattle {
  id             String          @id @default(cuid())
  tagNumber      String          @unique
  name           String
  birthDate      DateTime
  gender         String
  status         String
  weight         Float
  buildingId     String
  penNumber      Int
  memo           String?
  geneticFather  String?
  geneticMother  String?
  geneticGrade   String?
  weightHistory  String?
  lastEstrus     DateTime?
  pregnancyDate  DateTime?
  purchasePrice  Int?
  purchaseDate   DateTime?
  isArchived     Boolean         @default(false)
  archivedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  building       Building        @relation(fields: [buildingId], references: [id], onDelete: Restrict)
  salesRecords   SalesRecord[]
  scheduleEvents ScheduleEvent[]
  histories      CattleHistory[]
  expenses       ExpenseRecord[]

  @@index([buildingId, status])     // 동사별 상태 필터 (가장 빈번한 쿼리)
  @@index([status, isArchived])     // 활성 소 필터링
  @@index([buildingId, penNumber])  // 우사-우방 조회
}

model SalesRecord {
  id        String   @id @default(cuid())
  saleDate  DateTime
  price     Int
  purchaser String?
  grade     String?
  cattleId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cattle    Cattle   @relation(fields: [cattleId], references: [id], onDelete: Restrict)

  @@index([saleDate])               // 날짜 범위 쿼리
  @@index([cattleId, saleDate])     // 소별 판매 이력
}

model FeedStandard {
  id            String   @id @default(cuid())
  status        String   @unique
  roughage      String
  roughageKg    Float
  concentrate   String
  concentrateKg Float
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model InventoryItem {
  id        String   @id @default(cuid())
  name      String
  category  String
  quantity  Float
  unit      String
  threshold Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])               // 카테고리별 재고 조회
}

model ScheduleEvent {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  type        String
  cattleId    String?
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cattle      Cattle?  @relation(fields: [cattleId], references: [id], onDelete: SetNull)

  @@index([date, isCompleted])      // 일정 필터 (대시보드 메인)
  @@index([cattleId, date])         // 소별 일정 조회
}

model FeedRecord {
  id          String   @id @default(cuid())
  date        DateTime
  buildingId  String
  penNumber   Int?
  roughage    Float
  concentrate Float
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  building    Building @relation(fields: [buildingId], references: [id], onDelete: Restrict)

  @@index([buildingId, date])       // 동사별 급이 이력 조회
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String?
  status          String    @default("INACTIVE")
  billingKey      String?
  customerKey     String    @unique
  planName        String    @default("BASIC")
  amount          Int       @default(9900)
  nextPaymentDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model PaymentLog {
  id          String    @id @default(cuid())
  orderId     String    @unique
  paymentKey  String?
  amount      Int
  status      String
  requestedAt DateTime  @default(now())
  approvedAt  DateTime?
  receiptUrl  String?
  updatedAt   DateTime  @updatedAt
}

model ExpenseRecord {
  id          String    @id @default(cuid())
  date        DateTime
  cattleId    String?
  buildingId  String?
  category    String
  amount      Int
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cattle      Cattle?   @relation(fields: [cattleId], references: [id], onDelete: SetNull)
  building    Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)

  @@index([date])                   // 날짜 범위 비용 조회
  @@index([cattleId, date])         // 소별 비용 이력
  @@index([category, date])         // 카테고리별 비용 집계
}

model CattleHistory {
  id          String   @id @default(cuid())
  cattleId    String
  eventType   String
  eventDate   DateTime
  description String?
  metadata    String?
  createdAt   DateTime @default(now())
  cattle      Cattle   @relation(fields: [cattleId], references: [id], onDelete: Cascade)

  @@index([cattleId, eventDate])    // 소별 이력 조회 (시간순)
  @@index([eventType, eventDate])   // 이벤트 유형별 목록
}

model OutboxEvent {
  id          String       @id @default(cuid())
  topic       String
  aggregateId String?
  payload     Json
  status      OutboxStatus @default(PENDING)
  attempts    Int          @default(0)
  availableAt DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, availableAt, createdAt])
  @@index([topic, createdAt])
}

model DashboardSnapshot {
  key         String   @id
  payload     Json
  version     Int      @default(1)
  generatedAt DateTime @default(now())
  staleAt     DateTime

  @@index([staleAt])
}

model NotificationSummary {
  key         String   @id
  payload     Json
  generatedAt DateTime @default(now())
}

model MarketPriceSnapshot {
  id           String   @id @default(cuid())
  issueDate    DateTime @unique
  isRealtime   Boolean  @default(false)
  bullGrade1pp Int
  bullGrade1p  Int
  bullGrade1   Int
  cowGrade1pp  Int
  cowGrade1p   Int
  cowGrade1    Int
  source       String
  fetchedAt    DateTime @default(now())

  @@index([fetchedAt])
}
