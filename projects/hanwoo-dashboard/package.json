{
  "name": "hanwoo-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --test src/lib/action-validation.test.mjs src/lib/payment-confirmation.test.mjs src/lib/market-price-state.test.mjs src/lib/cattle-history.test.mjs",
    "smoke": "node scripts/smoke.mjs",
    "db:verify-indexes": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/verify-db-indexes.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "postbox:once": "node scripts/outbox-worker.mjs",
    "outbox:daemon": "node scripts/outbox-worker.mjs --daemon",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "next": "$next",
    "@tosspayments/payment-widget-sdk": {
      "typescript": ">=5.9.0"
    },
    "picomatch": "^4.0.4",
    "lodash": "^4.17.24",
    "brace-expansion": "^2.0.3",
    "effect": "^3.21.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@serwist/next": "^9.5.7",
    "@tosspayments/payment-widget-sdk": "^0.12.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.72.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.4",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.563.0",
    "next": "^16.2.1",
    "next-auth": "5.0.0-beta.30",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "recharts": "^2.12.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "prisma": "^7.6.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
