{
	"name": "hanwoo-dashboard",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev -p 3001",
		"build": "next build --webpack",
		"start": "next start",
		"lint": "eslint .",
		"knip": "knip",
		"test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test \"src/**/*.test.mjs\"",
		"smoke": "node scripts/smoke.mjs",
		"db:verify-indexes": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/verify-db-indexes.mjs",
		"db:prisma7-test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/prisma7-runtime-test.mjs",
		"db:generate": "prisma generate",
		"db:push": "prisma db push",
		"postbox:once": "node scripts/outbox-worker.mjs",
		"outbox:daemon": "node scripts/outbox-worker.mjs --daemon",
		"postinstall": "prisma generate"
	},
	"engines": {
		"node": ">=22.0.0",
		"npm": ">=10.0.0"
	},
	"overrides": {
		"react": "$react",
		"react-dom": "$react-dom",
		"next": "$next",
		"@tosspayments/payment-widget-sdk": {
			"typescript": ">=5.9.0"
		},
		"picomatch": "^4.0.4",
		"lodash": "^4.17.24",
		"brace-expansion": "^2.0.3",
		"effect": "^3.21.0",
		"postcss": "8.5.15",
		"@hono/node-server": "1.19.13"
	},
	"dependencies": {
		"@google/generative-ai": "^0.24.1",
		"@hookform/resolvers": "^5.4.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@radix-ui/react-avatar": "^1.2.0",
		"@radix-ui/react-dialog": "^1.1.17",
		"@radix-ui/react-label": "^2.1.10",
		"@radix-ui/react-progress": "^1.1.10",
		"@radix-ui/react-scroll-area": "^1.2.12",
		"@radix-ui/react-select": "^2.3.1",
		"@radix-ui/react-separator": "^1.1.10",
		"@radix-ui/react-slot": "^1.3.0",
		"@radix-ui/react-tabs": "^1.1.15",
		"@radix-ui/react-tooltip": "^1.2.10",
		"@serwist/next": "^9.5.11",
		"@tosspayments/payment-widget-sdk": "^0.12.2",
		"bcrypt": "^6.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.4.2",
		"ioredis": "^5.11.1",
		"lucide-react": "^1.21.0",
		"next": "^16.2.9",
		"next-auth": "5.0.0-beta.31",
		"qrcode.react": "^4.2.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-hook-form": "^7.79.0",
		"react-is": "^19.2.7",
		"recharts": "^3.8.1",
		"tailwind-merge": "^3.6.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.3.1",
		"eslint": "^9.39.4",
		"eslint-config-next": "^16.2.9",
		"knip": "^6.17.1",
		"prisma": "^7.8.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3"
	}
}
