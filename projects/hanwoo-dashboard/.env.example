# Joolife Hanwoo Dashboard environment template.
# Copy this file to `.env` and replace placeholders. Never commit real secrets.

# Required: Supabase/PostgreSQL connection for Prisma.
# Use the Supabase pooler URL after resetting/resyncing the database password.
DATABASE_URL="postgresql://postgres.<project-ref>:<database-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Required: Auth.js session signing and local callback URLs.
AUTH_SECRET="change-me-to-a-long-random-secret"
AUTH_URL="http://localhost:3001"
NEXTAUTH_URL="http://localhost:3001"
AUTH_TRUST_HOST="true"

# Optional: seed the first admin account with `node prisma/seed-admin.js`.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-to-a-12-plus-character-password"

# Optional: AI assistant and insight generation.
GEMINI_API_KEY=""

# Optional: Toss Payments subscription flow.
NEXT_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY=""
TOSS_PAYMENTS_SECRET_KEY=""

# Optional: Korean livestock market trace and market price APIs.
KAPE_SERVICE_KEY=""
MTRACE_SERVICE_KEY=""

# Optional: Redis-backed cache and BullMQ queues.
REDIS_URL=""
BULLMQ_REDIS_URL=""
REDIS_KEY_PREFIX="hd"
BULLMQ_PREFIX="hd:jobs"

# Optional: PWA build output. Leave disabled for normal local development.
NEXT_ENABLE_PWA="0"

# Optional: smoke-test port override.
SMOKE_PORT="3101"
