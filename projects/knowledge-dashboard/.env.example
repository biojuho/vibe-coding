# ── Knowledge Dashboard — environment template ────────────────────────────────
# Copy to `.env.local` (gitignored) and fill in real values.
# Every variable here is SERVER-SIDE ONLY. Never expose them to the browser
# (no NEXT_PUBLIC_ prefix) — see ADR-023 and src/lib/dashboard-auth.ts.

# REQUIRED — clients exchange this key at POST /api/auth/session for an
# httpOnly, HMAC-signed session cookie. Routes return 503 if this is unset and
# 401 if a request presents the wrong key. Use a long, random value.
DASHBOARD_API_KEY=change-me-to-a-long-random-secret

# OPTIONAL — dedicated HMAC secret for signing session cookies. Defaults to
# DASHBOARD_API_KEY when unset. Set a separate value so you can rotate the
# signing secret (invalidating all live sessions) without changing the login key.
DASHBOARD_SESSION_SECRET=

# OPTIONAL — used by scripts/sync_data.py to fetch GitHub repository activity.
# A fine-grained PAT with read-only "repositories" access is enough.
GITHUB_PERSONAL_ACCESS_TOKEN=

# OPTIONAL — override the NotebookLM auth token file used during sync.
# Relative paths resolve from the workspace root. Defaults to
# infrastructure/notebooklm-mcp/tokens/auth.local.json then auth.json.
NOTEBOOKLM_AUTH_TOKEN_PATH=
