{
	"name": "suika-game-v2",
	"version": "3.0.0",
	"description": "Suika Daily - a deterministic, Wordle-style daily fruit-merge challenge built with Matter.js",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "node scripts/prebuild-check.js && vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint .",
		"gen:ppt": "node scripts/generate_ppt.js"
	},
	"dependencies": {
		"matter-js": "^0.20.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@vitest/coverage-v8": "^4.1.6",
		"eslint": "^9.39.1",
		"globals": "^16.5.0",
		"jsdom": "^28.1.0",
		"pptxgenjs": "^4.0.1",
		"vite": "^7.2.4",
		"vitest": "^4.1.6"
	}
}
