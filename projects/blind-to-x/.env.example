# Copy to .env and fill with real values. Do not commit populated secret files.
AUTO_PUBLISH=false

NOTION_API_KEY=
NOTION_DATABASE_ID=

BLIND_EMAIL=
BLIND_PASSWORD=

GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
MOONSHOT_API_KEY=
ZHIPUAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 이미지 생성 (OpenAI). 켜려면 true 로 두고 OPENAI_API_KEY 를 채웁니다.
OPENAI_IMAGE_ENABLED=false

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# 성과 수집용 API 키 (performance_collector.py)
# X(Twitter) API Bearer Token (성과 읽기용: Basic tier 이상)
X_BEARER_TOKEN=
# Meta Threads Graph API Access Token (성과 읽기용)
THREADS_ACCESS_TOKEN=

# [Phase 7] 실시간 RAG 인리치먼트 엔진 (enrichment_engine.py)
EXA_API_KEY=                  # Exa (ex-Metaphor) AI Search API Key (https://exa.ai)
PERPLEXITY_API_KEY=           # Perplexity AI API Key (sonar-pro 모델 사용)

# 관측성 / 운영 토글 (README "관측성" 섹션 참고). 기본 비활성.
LANGFUSE_ENABLED=0            # 1 이면 LLM 호출 트레이스를 워크스페이스 Langfuse 로 전송
BTX_USAGE_FORWARD=0           # 1 이면 사용량을 워크스페이스 .tmp/workspace.db 로 미러링
