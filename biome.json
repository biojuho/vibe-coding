{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!qc_results.json",
			"!.tmp",
			"!.venv",
			"!venv",
			"!node_modules",
			"!dist",
			"!.turbo",
			"!projects/hanwoo-dashboard/public/sw.js",
			"!projects/hanwoo-dashboard/.next",
			"!projects/knowledge-dashboard/.next"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
