# Recommended DeepSeek Korean bridge defaults
# Copy the values you want into your real `.env`.

LLM_BRIDGE_MODE=shadow
LLM_BRIDGE_TARGET_LANGUAGE=ko-KR
LLM_BRIDGE_ALLOWED_TERMS=DeepSeek,JSON,OpenAI,YouTube,Shorts,Blind,X
LLM_BRIDGE_FALLBACKS=deepseek,google,openai
LLM_BRIDGE_REPAIR_ATTEMPTS=1
LLM_BRIDGE_STRICT_KOREAN=true
LLM_BRIDGE_ENFORCE_JSON_SCHEMA=true
LLM_BRIDGE_MIN_HANGUL_RATIO=0.72
LLM_BRIDGE_MAX_CJK_RATIO=0.03
LLM_BRIDGE_MAX_JAMO_RATIO=0.05
LLM_BRIDGE_JSON_KEY_EXEMPTIONS=title,id,url,slug
