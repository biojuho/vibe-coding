# ============================================================
# Vibe Coding - .gitignore (Private Backup 용)
# 목적: 전체 프로젝트 코드 백업 (보안 민감 파일 제외)
# ============================================================

# ===== 보안 (절대 커밋 금지) =====
.env
.env.*
!.env.example
credentials.json
token.json
*.pem
*.key

# ===== 런타임 출력물 =====
.tmp/
.tmp/reports/
**/logs/
test_audio/
backups/
*.log
coverage.xml
report.xml
report_unit*.xml
cov*.txt
result*.txt
test_out*.txt
*.tsbuildinfo
pytest*.txt
pytest_*.txt
ruff*.txt
ruff*.json
**/check_failed.txt
**/failures.txt
**/old_patch.txt
**/.coverage_latest_report.txt
test_errors.txt

# ===== Python 캐시/아티팩트 =====
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
**/.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/

# ===== 가상환경 =====
venv/
.venv/
**/venv/
**/.venv/

# ===== JavaScript 빌드 캐시 =====
**/node_modules/
**/.next/
**/dist/
**/build/
**/.turbo/

# ===== AI 도구 로컬 설정 (각 도구 고유) =====
.agent/
.agents/skills/_archive/
.claude/
.codex/
.vscode/
.gemini/

# ===== Nested Git Repos (renamed for root backup) =====
**/.git.bak/

# ===== OS =====
.DS_Store
Thumbs.db
desktop.ini

# ===== Docker =====
infrastructure/n8n/logs/

# ===== 미사용/아카이브 프로젝트 =====
_archive/
champion-roulette/
discord-bot/
escape-room/
esports-alert/
profit-content-generator/
shorts-maker/
stat-card-maker/
word-chain-pygame/
