# ============================================================
# Vibe Coding - .gitignore (Private Backup 용)
# 목적: 전체 프로젝트 코드 백업 (보안 민감 파일 제외)
# ============================================================

# ===== 보안 (절대 커밋 금지) =====
.env
.env.*
!.env.example
credentials.json
token.json
*.pem
*.key
.agents/skills/brave-search/secrets.local.json
infrastructure/notebooklm-mcp/tokens/auth.local.json

# ===== 런타임 출력물 =====
.tmp/

# T-254 — Notion에서 자동 생성되는 평가 데이터셋 (콘텐츠 민감)
tests/eval/blind-to-x/golden_cases.yaml
tests/eval/blind-to-x/rejected_cases.yaml

.tmp/reports/
**/logs/
test_audio/
backups/
*.log
coverage.xml
coverage.json
report.xml
report_unit*.xml
cov*.txt
.cov_report.json
result*.txt
test_out*.txt
*.tsbuildinfo
pytest*.txt
pytest_*.txt
ruff*.txt
ruff*.json
**/check_failed.txt
**/failures.txt
**/old_patch.txt
**/.coverage_latest_report.txt
test_errors.txt
# 디버깅 임시 파일
t121_*.txt
tmp_*.txt
tmp_*.py
temp_*.txt
node_err.txt
o.txt

# ===== Python 캐시/아티팩트 =====
