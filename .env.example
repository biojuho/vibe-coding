# ============================================================
# Vibe Coding - Environment Variables Template
# 복사하여 .env로 만들고 실제 값을 채워 넣으세요
# ============================================================

# === LLM API Keys ===
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=your-google-api-key
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
MOONSHOT_API_KEY=sk-...
ZHIPUAI_API_KEY=your-zhipuai-key
XAI_API_KEY=xai-...
GEMINI_API_KEY=AIza...

# === Cloud Services ===
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# === Notion ===
NOTION_API_KEY=ntn_...
NOTION_DATABASE_ID=your-database-id
NOTION_SHORTS_DATABASE_ID=your-shorts-db-id
NOTION_TRACKING_DB_ID=your-tracking-db-id

# === YouTube ===
YOUTUBE_API_KEY=AIza...

# === Telegram ===
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_ENABLED=true

# === GitHub ===
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# === Brave Search ===
BRAVE_API_KEY=BSA...

# === n8n Bridge ===
BRIDGE_TOKEN=your-bridge-token
BRIDGE_URL=http://localhost:9876

# === Project ===
PROJECT_ROOT=C:\Users\[USERNAME]\Desktop\Vibe coding
