# ============================================================
# Vibe Coding - Environment Variables Template
# ============================================================
#
# 환경변수가 역할별로 분리되었습니다:
#   .env.llm     — LLM API 키
#   .env.social  — 외부 서비스 (Notion, YouTube, Cloudinary)
#   .env.project — 프로젝트 설정
#   .env         — 레거시 호환 (모든 키 통합)
#
# 새 코드: execution/_env_loader.py의 load_all_env() 사용
# 기존 코드: load_dotenv()는 .env에서 모든 키를 로드
#
# 설정 방법:
#   1. 이 파일을 .env로 복사하고 실제 값을 채워 넣으세요
#   2. 또는 .env.llm, .env.social, .env.project를 각각 생성하세요

# === LLM API Keys (.env.llm) ===
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=your-google-api-key
GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
MOONSHOT_API_KEY=sk-...
ZHIPUAI_API_KEY=your-zhipuai-key
XAI_API_KEY=xai-...
MIMO_API_KEY=sk-...

# === Social & External Services (.env.social) ===
NOTION_API_KEY=ntn_...
NOTION_DATABASE_ID=your-database-id
NOTION_SHORTS_DATABASE_ID=your-shorts-db-id
NOTION_TRACKING_DB_ID=your-tracking-db-id
YOUTUBE_API_KEY=AIza...
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# === Telegram ===
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_ENABLED=true

# === GitHub ===
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# === Brave Search ===
BRAVE_API_KEY=BSA...

# === NotebookLM ===
NOTEBOOKLM_AUTH_TOKEN_PATH=infrastructure/notebooklm-mcp/tokens/auth.local.json

# === n8n Bridge ===
BRIDGE_TOKEN=your-bridge-token
BRIDGE_URL=http://localhost:9876
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-before-use

# === Langfuse 셀프호스트 (T-253, opt-in) ===
# 기본 OFF — 1로 변경 시 LLMClient가 trace를 로컬 Langfuse 컨테이너에 송신.
# 인프라/UI 셋업은 infrastructure/langfuse/README.md 참조.
LANGFUSE_ENABLED=0
LANGFUSE_HOST=http://127.0.0.1:3030
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# docker-compose 기동에만 필요 (opt-in 활성 후)
LANGFUSE_DB_PASSWORD=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_CLICKHOUSE_PASSWORD=
LANGFUSE_REDIS_AUTH=
LANGFUSE_MINIO_ROOT_PASSWORD=

# === Project Settings (.env.project) ===
PROJECT_ROOT=C:\Users\[USERNAME]\Desktop\Vibe coding
